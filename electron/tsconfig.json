{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "outDir": "dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["./*.ts", "../src/*.ts"]
}
