{
  "name": "simple-bible-study-tool",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply simple-bible-study-tool --local",
    "db:migrate:remote": "wrangler d1 migrations apply simple-bible-study-tool --remote",
    "set-password": "node scripts/set-password.mjs",
    "electron:install": "npm install --prefix electron",
    "electron:dev": "npm run --prefix electron dev",
    "electron:package": "npm run --prefix electron package",
    "electron:release": "npm run --prefix electron release"
  },
  "devDependencies": {
    "typescript": "^5.5.2",
    "wrangler": "^4.99.0"
  }
}
